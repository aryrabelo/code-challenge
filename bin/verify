#!/usr/bin/env ruby
# frozen_string_literal: true

# Offline correctness proof. Parses the official challenge fixture with
# SerpapiCodeChallenge::CarouselParser and diffs the result against the official expected-array.json,
# field by field. Runs with nothing but a system Ruby + Nokogiri — no Bundler,
# no RSpec — so it is always runnable as a smoke test.
#
#   bin/verify            # => "PERFECT 47/47" and exit 0, or a diff and exit 1

root = File.expand_path("..", __dir__)
$LOAD_PATH.unshift File.join(root, "lib")
require "json"
require "carousel_parser"

html = File.join(root, "files/van-gogh-paintings.html")
expected = JSON.parse(File.read(File.join(root, "files/expected-array.json")))["artworks"]
got = SerpapiCodeChallenge::CarouselParser.from_file(html).to_h["artworks"] # string-keyed, oracle-shaped

puts "extracted: #{got.length}  expected: #{expected.length}"
mismatches = 0
got.zip(expected).each_with_index do |(g, e), i|
  if g.nil?
    mismatches += 1
    puts "  item[#{i}] MISSING"
    next
  end
  %w[name extensions link image].each do |key|
    next if g[key] == e[key]

    mismatches += 1
    next if mismatches > 8

    gv = g[key].is_a?(String) ? g[key][0, 60] : g[key].inspect
    ev = e[key].is_a?(String) ? e[key][0, 60] : e[key].inspect
    puts "  MISMATCH item[#{i}].#{key}\n    got=#{gv}\n    exp=#{ev}"
  end
end

if mismatches.zero?
  puts "RESULT: PERFECT #{got.length}/#{expected.length} — all fields match the oracle ✅"
  exit 0
else
  puts "RESULT: #{mismatches} field mismatches ❌"
  exit 1
end
