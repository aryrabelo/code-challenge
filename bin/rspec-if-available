#!/usr/bin/env bash
# TDD gate used by Lefthook. Runs the full RSpec suite through the mise-pinned
# toolchain (NEVER the system Ruby). Falls back to the dependency-free offline
# oracle check (bin/verify) only when mise/bundler are not yet set up, so the
# gate is always enforceable.
set -euo pipefail
cd "$(dirname "$0")/.."

if command -v mise >/dev/null 2>&1 && [ -f mise.toml ]; then
  if mise exec -- bundle exec rspec --version >/dev/null 2>&1; then
    exec mise exec -- bundle exec rspec
  fi
fi

echo "[hook] mise/bundler not ready — running offline bin/verify gate via mise."
if command -v mise >/dev/null 2>&1; then
  exec mise exec -- ruby bin/verify
fi
exec ruby bin/verify
